# TRAD web client environment
# Copy this file to .env.local for local development.
# Only VITE_* variables are exposed to browser code. Do not put secrets here.

# Authentication is handled by the gateway BFF. Keep Auth0 client secrets in
# the gateway env, not in browser-exposed VITE_* variables.

# API routing
# Browser requests use VITE_API_BASE. In dev, /api and /auth are proxied by Vite.
VITE_API_BASE=/api
VITE_API_TARGET=http://localhost:8080

# WebSocket endpoint
# Leave blank to derive from the current origin, for example http://localhost:5173 -> ws://localhost:5173/ws.
VITE_WS_URL=
# Dev proxy target for /ws when VITE_WS_URL is blank.
VITE_WS_TARGET=ws://localhost:8081

# Build/runtime metadata
VITE_APP_BUILD=dev
VITE_LOG_LEVEL=info

# Stripe client-side/public identifiers
# These are optional fallbacks for local pricing UI defaults.
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me
VITE_STRIPE_PRICING_TABLE_ID=
VITE_STRIPE_PRICE_STARTER=price_starter
VITE_STRIPE_PRICE_PRO=price_pro
VITE_STRIPE_PRICE_ENTERPRISE=price_enterprise
